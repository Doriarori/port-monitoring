# Copy to .env and fill in. docker-compose reads these automatically.

# ── Authentication ─────────────────────────────────────────────────────────
# Users live in the DB (roles: admin | readonly) and are managed via the Users
# tab / REST API. The vars below define the BOOTSTRAP admin: seeded on first
# start when the users table is empty, and always accepted as a fallback
# super-admin so you can never lock yourself out.
# Auth is ON by default — set AUTH_ENABLED=false to disable (e.g. behind a
# trusted reverse proxy that already authenticates).
AUTH_ENABLED=true
ADMIN_USERNAME=admin
# Required when auth is enabled — choose a strong password.
ADMIN_PASSWORD=change-me
# Required when auth is enabled — secret used to sign JWTs.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=
# Token lifetime in minutes (default 720 = 12h).
JWT_EXPIRE_MINUTES=720

# ── Database (optional override) ───────────────────────────────────────────
# DATABASE_URL=postgresql://portmon:portmon@db:5432/portmon
